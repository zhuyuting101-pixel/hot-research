# ── 开发环境 ──────────────────────────────────────────────────
# Mock 开关：true = 全走 mock（无需启动 backend）
#            false = 走 vite proxy → http://localhost:3001
VITE_USE_MOCK=false

# ── 生产环境 ──────────────────────────────────────────────────
# 部署后 /api 请求不经过 vite proxy（proxy 仅在 dev server 生效）。
# 需设置此变量指向后端的完整域名，apiFetch() 会拼接为：
#   ${VITE_API_BASE}/api/hot/weibo
# 示例（Vercel / Railway 部署地址）：
# VITE_API_BASE=https://hotsearch-backend.railway.app
VITE_API_BASE=
